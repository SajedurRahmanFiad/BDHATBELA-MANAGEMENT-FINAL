# Copy this to .env.local and fill in your Supabase project values

# Frontend keys (public, safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_API_BASE_URL=/api/
VITE_API_PROXY_TARGET=http://127.0.0.1:8001

# Egress controls (disabled by default; enable only when needed)
VITE_ENABLE_REALTIME=false
VITE_ENABLE_CARRYBEE_SYNC=false
VITE_DB_WRITE_FREEZE=false
VITE_DB_WRITE_FREEZE_TITLE=Read-only incident mode
VITE_DB_WRITE_FREEZE_MESSAGE=Database writes are temporarily disabled for maintenance. You can keep using the app in read-only mode.

# Backend keys (KEEP SECRET - for server-side operations only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
APP_JWT_SECRET=change-this-secret
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bdhatbela_management
DB_USER=root
DB_PASS=

# Do NOT commit your .env.local with real keys to source control
